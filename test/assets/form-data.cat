<%
const body = request.body;
const upload = body && body.files && Array.isArray(body.files.upload) ? body.files.upload[0] : null;
const uploadBinary = body && body.files && Array.isArray(body.files.uploadBinary) ? body.files.uploadBinary[0] : null;
const uploadMulti = body && body.files ? body.files.uploadMulti : null;
%>
<%- JSON.stringify({
    type: body ? body.type : null,
    body: body ? body.body : null,
    uploadIsArray: !!(body && body.files && Array.isArray(body.files.upload)),
    uploadBinaryIsArray: !!(body && body.files && Array.isArray(body.files.uploadBinary)),
    file: upload ? {
        name: upload.name,
        mimetype: upload.mimetype,
        size: upload.size,
        hasRead: typeof upload.arrayBuffer === 'function',
        text: upload.text(),
    } : null,
    binaryFile: uploadBinary ? {
        name: uploadBinary.name,
        mimetype: uploadBinary.mimetype,
        size: uploadBinary.size,
        bytes: Array.from(new Uint8Array(uploadBinary.arrayBuffer())),
    } : null,
    multiFiles: Array.isArray(uploadMulti) ? uploadMulti.map((file) => ({
        name: file.name,
        mimetype: file.mimetype,
        size: file.size,
        text: file.text(),
    })) : null,
}) %>
